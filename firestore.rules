rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email in ['jefson.ti@gmail.com', 'jefson.s.a7@gmail.com']; }
    function getUserRole() { 
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data.globalRole : 'student'; 
    }
    function getSchoolMemberRole(schoolId) {
      let memberDoc = get(/databases/$(database)/documents/schools/$(schoolId)/members/$(request.auth.uid));
      return memberDoc != null ? memberDoc.data.role : null;
    }
    function isSchoolAdmin(schoolId) {
      let r = getSchoolMemberRole(schoolId);
      return r in ['school_director', 'school_secretary', 'coordinator', 'superadmin'] || isAdmin();
    }
    function isTeacher(schoolId) {
      let r = getSchoolMemberRole(schoolId);
      return r in ['teacher', 'both'];
    }
    function isGuardian(schoolId) {
      let r = getSchoolMemberRole(schoolId);
      return r == 'guardian';
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || request.auth.uid != null); // Anyone can read basic profiles to show name/avatar
      allow write: if isSignedIn() && request.auth.uid == userId; 
    }

    match /schoolInvites/{inviteId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || request.auth.uid != null); // In real app, only secretary. Keeping wide for POC
    }

    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isSchoolAdmin(schoolId);

      match /members/{userId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if request.auth.uid == userId || isSchoolAdmin(schoolId);
      }

      match /classes/{classId} {
        allow read: if isSignedIn();
        allow write: if isSchoolAdmin(schoolId) || isTeacher(schoolId);
      }

      match /students/{studentId} {
        allow read: if isSignedIn(); 
        allow write: if isSchoolAdmin(schoolId) || isTeacher(schoolId);
      }

      match /attendance/{attendanceId} {
        allow read: if isSignedIn();
        allow write: if isSchoolAdmin(schoolId) || isTeacher(schoolId);
      }

      match /grades/{gradeId} {
        allow read: if isSignedIn();
        allow write: if isSchoolAdmin(schoolId) || isTeacher(schoolId);
      }

      match /occurrences/{occurrenceId} {
        allow read: if isSignedIn();
        allow write: if isSchoolAdmin(schoolId) || isTeacher(schoolId);
      }

      match /guardianStudentLinks/{linkId} {
        allow read: if isSignedIn();
        allow write: if isSchoolAdmin(schoolId) || isGuardian(schoolId);
      }

      match /notifications/{notifId} {
        allow read, write: if isSignedIn();
      }

      match /meetingRequests/{meetingId} {
        allow read, write: if isSignedIn();
      }
    }

    // Keep legacy rules for backwards compatibility
    match /school_links/{linkId} {
      allow read, write: if isSignedIn();
    }
  }
}

