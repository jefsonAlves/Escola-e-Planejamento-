rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email in ['jefson.ti@gmail.com', 'jefson.s.a7@gmail.com']; }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /schoolInvites/{inviteId} {
      allow read, write: if isSignedIn();
    }

    match /schools/{schoolId} {
      allow read, write: if isSignedIn();

      match /members/{userId} {
        allow read, write: if isSignedIn();
      }

      match /classes/{classId} {
        allow read, write: if isSignedIn();
      }

      match /students/{studentId} {
        allow read, write: if isSignedIn();
      }

      match /attendance/{attendanceId} {
        allow read, write: if isSignedIn();
      }

      match /grades/{gradeId} {
        allow read, write: if isSignedIn();
      }

      match /occurrences/{occurrenceId} {
        allow read, write: if isSignedIn();
      }

      match /guardianStudentLinks/{linkId} {
        allow read, write: if isSignedIn();
      }

      match /notifications/{notifId} {
        allow read, write: if isSignedIn();
      }

      match /meetingRequests/{meetingId} {
        allow read, write: if isSignedIn();
      }
    }

    match /school_links/{linkId} {
      allow read, write: if isSignedIn();
    }
    
    match /{document=**} {
      allow read, write: if isSignedIn() && isAdmin();
    }
  }
}

