rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jefson.ti@gmail.com' ||
        request.auth.token.email == 'jefson.s.a7@gmail.com'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validations
    function isValidUser(data) {
      return data.keys().hasAll(['schoolName', 'teacherName', 'updatedAt'])
        && data.schoolName is string && data.schoolName.size() <= 200
        && data.teacherName is string && data.teacherName.size() <= 100
        && data.updatedAt == request.time
        && (!('role' in data) || data.role in ['teacher', 'student', 'both'])
        && (!('classesStr' in data) || data.classesStr is string && data.classesStr.size() <= 100000)
        && (!('occurrencesStr' in data) || data.occurrencesStr is string && data.occurrencesStr.size() <= 100000)
        && (!('cpf' in data) || data.cpf is string && data.cpf.size() <= 50)
        && (!('birthDate' in data) || data.birthDate is string && data.birthDate.size() <= 50)
        && (!('password' in data) || data.password is string && data.password.size() <= 200)
        && (!('googleSynced' in data) || data.googleSynced is bool)
        && (!('avatarUrl' in data) || data.avatarUrl == null || data.avatarUrl is string && data.avatarUrl.size() <= 1000)
        && (!('googleCalendarEventsStr' in data) || data.googleCalendarEventsStr is string && data.googleCalendarEventsStr.size() <= 100000)
        && (!('googleClassroomActivitiesStr' in data) || data.googleClassroomActivitiesStr is string && data.googleClassroomActivitiesStr.size() <= 100000);
    }

    function isValidSchool(data) {
      return data.keys().hasAll(['name', 'createdAt'])
        && data.name is string && data.name.size() <= 200
        && data.createdAt == request.time;
    }

    function isValidSchoolLink(data) {
      return data.keys().hasAll(['teacherId', 'teacherName', 'schoolName', 'originalClassId', 'className', 'studentsCount', 'status', 'requestedAt'])
        && data.teacherId == request.auth.uid
        && data.teacherName is string && data.teacherName.size() <= 100
        && data.schoolName is string && data.schoolName.size() <= 200
        && data.originalClassId is string && data.originalClassId.size() <= 100
        && data.className is string && data.className.size() <= 100
        && data.studentsCount is int
        && data.status is string && data.status.size() <= 50
        && data.requestedAt == request.time;
    }

    // Match users collection
    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        resource.data.schoolName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolName
      );

      allow list: if isSignedIn() && (
        isAdmin() ||
        resource.data.schoolName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolName
      );

      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());

      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['schoolName', 'teacherName', 'birthDate', 'cpf', 'password', 'googleSynced', 'avatarUrl', 'role', 'classesStr', 'occurrencesStr', 'googleCalendarEventsStr', 'googleClassroomActivitiesStr', 'updatedAt'])
      );

      allow delete: if isAdmin();
    }

    // Match schools collection
    match /schools/{schoolId} {
      allow read, list: if true; // Let users select schools prior to fully entering home
      allow create: if isSignedIn() && isValidSchool(incoming());
      allow update, delete: if isAdmin();
    }

    // Match school_links collection
    match /school_links/{linkId} {
      allow create: if isSignedIn() && isValidSchoolLink(incoming());
      allow read, list, update, delete: if isSignedIn() && (resource.data.teacherId == request.auth.uid || isAdmin());
    }

    // Match api_keys collection
    match /api_keys/{apiKeyId} {
      allow read, write: if isAdmin();
    }

    // Match webhooks collection
    match /webhooks/{webhookId} {
      allow read, write: if isAdmin();
    }
  }
}
